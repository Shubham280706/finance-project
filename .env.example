# ── Required ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
DATABASE_URL=                  # Supabase Postgres connection string (pooled)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=     # server-side only, for storage + RPC

# ── Optional (graceful fallback if absent) ────────────────────────────
LLAMA_CLOUD_API_KEY=           # if set, use LlamaParse for better tables; else unpdf
GENERATION_MODE=quality        # "quality" -> sonnet, "cheap" -> haiku
NEXT_PUBLIC_SITE_URL=          # public base URL for email verification links
                               # (e.g. https://your-app.vercel.app). Falls back
                               # to the browser origin (localhost) when unset.
